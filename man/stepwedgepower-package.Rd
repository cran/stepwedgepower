\name{stepwedgepower-package}
\alias{stepwedgepower-package}
\title{stepwedgepower: Tools for stepped-wedge clinical trial analysis and power simulation}
\description{
The \pkg{stepwedgepower} package refactors a one-off academic analysis script
into reusable tools for physician-level data preparation, specialty-level rate
modeling, and simulation-based planning for stepped-wedge studies.
}
